generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  name      String
  password  String
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rateCards RateCard[]
}

model RateCard {
  id     String @id @default(auto()) @map("_id") @db.ObjectId
  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Creator inputs — saved so user can revisit exact state
  platform       String
  niche          String
  followers      Int
  engagementRate Float
  city           String
  deliverable    String

  // Calculated outputs — stored so history is stable even if formula changes
  floorRate   Int
  midRate     Int
  premiumRate Int

  // Metadata
  label     String? // optional user-given name e.g. "My fashion pitch"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Benchmark {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  version   String   @unique // e.g. "v1" — bump when rates change
  data      Json // full multiplier config stored as JSON
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
